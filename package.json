{
  "name": "opscanon",
  "version": "0.1.0",
  "description": "Turn messy company knowledge into verified agent skills and MCP-ready company brains.",
  "type": "module",
  "bin": {
    "opscanon": "dist/cli.js",
    "ai-repo-readiness": "dist/cli.js",
    "company-brain": "dist/cli.js"
  },
  "keywords": [
    "opscanon",
    "ai-agents",
    "agent-readiness",
