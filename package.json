    "repo-audit",
    "company-brain",
    "knowledge-ops",
    "skillops",
    "codex",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Keyroler1/opscanon.git"
  },
  "bugs": {
    "url": "https://github.com/Keyroler1/opscanon/issues"
  },
  "homepage": "https://keyroler1.github.io/opscanon/",
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "examples",
    "site"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test:coverage && npm run typecheck && npm run build",
